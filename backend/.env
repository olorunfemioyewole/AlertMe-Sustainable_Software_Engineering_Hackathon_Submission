# ── USSD Service (port 8000) ──────────────────────────────────────────────────
# Supabase PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
SUPABASE_DB_URL=postgresql://postgres:[_gzWyscmJAv97f6]@db.rpqqxedtspfdcortfxat.supabase.co:5432/postgres

# Africa's Talking sandbox credentials
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox

# ── Mobile API (port 8001) ────────────────────────────────────────────────────
# URL of the running core engine
ENGINE_URL=http://localhost:8002

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Token lifetime in minutes
JWT_EXPIRE_MINUTES=60

# SQLite file path for mobile app user accounts
DB_PATH=safealert_users.db

# ── Core Engine (port 8002) ───────────────────────────────────────────────────
# SQLite database file for incidents and dispatch logs
DATABASE_URL=sqlite+aiosqlite:///./safealert.db
